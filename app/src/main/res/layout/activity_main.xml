<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/subtitle"
            android:textSize="14sp"
            android:layout_marginBottom="24dp" />

        <!-- Prerequisite banner -->
        <LinearLayout
            android:id="@+id/prereqBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="?android:attr/colorBackgroundFloating"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/prereq_header"
                android:textSize="12sp"
                android:textAllCaps="true"
                android:textStyle="bold"
                android:alpha="0.6"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/txtPrereq"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="15sp"
                android:lineSpacingExtra="2dp"
                android:layout_marginBottom="12dp"
                android:text="@string/prereq_body" />

            <Button
                android:id="@+id/btnPrimary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/btn_install_shizuku" />

            <Button
                android:id="@+id/btnSecondary"
                style="?attr/borderlessButtonStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/btn_open_shizuku"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Routing -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/launcher_header"
            android:textSize="12sp"
            android:textAllCaps="true"
            android:textStyle="bold"
            android:alpha="0.6"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/launcher_open_label"
            android:textSize="14sp"
            android:layout_marginBottom="2dp" />
        <TextView
            android:id="@+id/txtLauncherOpen"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp"
            android:textSize="15sp"
            android:background="?android:attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/launcher_close_label"
            android:textSize="14sp"
            android:layout_marginBottom="2dp" />
        <TextView
            android:id="@+id/txtLauncherClose"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp"
            android:textSize="15sp"
            android:background="?android:attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginBottom="24dp" />

        <!-- Default home -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/home_role_header"
            android:textSize="12sp"
            android:textAllCaps="true"
            android:textStyle="bold"
            android:alpha="0.6"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/txtHomeHolder"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:fontFamily="monospace"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnMakeHome"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_make_home"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/home_role_note"
            android:textSize="12sp"
            android:alpha="0.7"
            android:layout_marginBottom="24dp" />

        <!-- Rotation -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/rotation_header"
            android:textSize="12sp"
            android:textAllCaps="true"
            android:textStyle="bold"
            android:alpha="0.6"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/swForceRotation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/rotation_label"
            android:textSize="15sp"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/rotation_note"
            android:textSize="12sp"
            android:alpha="0.7"
            android:layout_marginBottom="16dp" />

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/swForceFullscreen"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/fullscreen_label"
            android:textSize="15sp"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/fullscreen_note"
            android:textSize="12sp"
            android:alpha="0.7"
            android:layout_marginBottom="24dp" />

        <!-- Status -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/status_header"
            android:textSize="12sp"
            android:textAllCaps="true"
            android:textStyle="bold"
            android:alpha="0.6"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/txtShizukuInstalled"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:fontFamily="monospace"
            android:layout_marginBottom="2dp" />
        <TextView
            android:id="@+id/txtShizuku"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:fontFamily="monospace"
            android:layout_marginBottom="2dp" />
        <TextView
            android:id="@+id/txtPerm"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:fontFamily="monospace"
            android:layout_marginBottom="2dp" />
        <TextView
            android:id="@+id/txtBound"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:fontFamily="monospace"
            android:layout_marginBottom="2dp" />
        <TextView
            android:id="@+id/txtWatch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:fontFamily="monospace"
            android:layout_marginBottom="2dp" />
        <TextView
            android:id="@+id/txtHingeState"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:fontFamily="monospace"
            android:layout_marginBottom="2dp" />
        <TextView
            android:id="@+id/txtLast"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:fontFamily="monospace"
            android:layout_marginBottom="16dp" />

        <Button
            android:id="@+id/btnStop"
            style="?attr/borderlessButtonStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_stop"
            android:visibility="gone" />
    </LinearLayout>
</ScrollView>
